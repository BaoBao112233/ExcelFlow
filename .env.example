# AI Provider Configuration
# Chọn provider bạn muốn sử dụng: openai, anthropic, google, groq, vertex
AI_PROVIDER=openai

# Model name (optional - sẽ dùng default nếu không set)
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
# Google: gemini-1.5-pro, gemini-1.5-flash
# Groq: llama-3.3-70b-versatile, llama-3.1-70b-versatile, mixtral-8x7b-32768
# Vertex: gemini-1.5-pro, gemini-1.5-flash
AI_MODEL=gpt-4o

# AI Parameters
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# API Keys - Chỉ cần set key cho provider bạn dùng
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Vertex AI (enterprise Google)
# Vertex dùng GCP project ID + service account JSON file
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# Path to service account JSON file (REQUIRED for Vertex AI)
# Tạo service account tại: https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant role: "Vertex AI User"
# Download JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
